  "faqs": [
    {
      "question": "Is the meat Halal?",
      "answer": "Yes, all meat served at the Eid BBQ is 100% Halal certified and sourced from local artisanal butchers."
    },
    {
      "question": "Can I bring my own food?",
      "answer": "While we provide a full feast, you are welcome to bring specific dietary items or your favorite home-cooked sides to share with your family."
    },
    {
      "question": "What should I bring?",
      "answer": "We recommend bringing folding chairs, picnic blankets, and sun protection. We provide the food, drinks, and basic seating under the pavilion."
    },
    {
      "question": "Is there a prayer area?",
      "answer": "Yes, a designated quiet area with prayer mats will be available for Dhuhr and Asr prayers."
    },
    {
      "question": "What happens if it rains?",
      "answer": "The Riverside Pavilion is covered, so the BBQ will go ahead rain or shine! In case of extreme weather, we will notify everyone via the community WhatsApp group."
    }
  ]
